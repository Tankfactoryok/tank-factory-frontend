---
const { title, items } = Astro.props;
---
<section class="max-w-7xl mx-auto px-6 py-24 mb-20 bg-slate-50/50 rounded-[3rem] border border-slate-100 shadow-inner">
  <div class="text-center mb-20 max-w-4xl mx-auto">
    <span class="inline-block bg-blue-100 text-blue-700 text-xs font-black px-4 py-2 rounded-full uppercase tracking-[0.2em] mb-6">Core Engineering</span>
    <h2 class="text-4xl md:text-6xl font-black text-slate-900 tracking-tight leading-tight">{title}</h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
    {items && items.map((item: any) => (
      <div class="group bg-white p-12 rounded-[2.5rem] border border-slate-200 shadow-sm hover:shadow-2xl hover:border-blue-300 hover:-translate-y-3 transition-all duration-500 flex flex-col">
        <div class="w-20 h-20 rounded-3xl bg-blue-50 border border-blue-100 flex items-center justify-center mb-10 group-hover:bg-blue-600 group-hover:rotate-6 transition-all duration-500">
           {/* 图标显示 */}
           <span class="text-4xl text-blue-600 group-hover:text-white">{item.lucide_icon_name || '⚙️'}</span>
        </div>
        <h3 class="text-2xl font-extrabold text-slate-900 mb-6 tracking-tight group-hover:text-blue-700">{item.heading}</h3>
        <p class="text-slate-600 leading-relaxed text-lg">{item.description}</p>
      </div>
    ))}
  </div>
</section>