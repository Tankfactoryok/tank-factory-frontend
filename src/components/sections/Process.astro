---
const { title, subtitle, items } = Astro.props;
---
<section class="py-24 bg-white overflow-hidden relative">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="text-center max-w-3xl mx-auto mb-20">
      <span class="text-blue-600 font-bold tracking-widest text-sm uppercase">Production Flow</span>
      <h2 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tighter mt-4">
        {title || "Precision Manufacturing Process"}
      </h2>
      {subtitle && <p class="text-slate-500 mt-6 text-lg">{subtitle}</p>}
    </div>

    {/* 流程卡片网格 */}
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-8">
      {items && items.map((item: any, index: number) => (
        <div class="relative bg-slate-50 rounded-3xl p-8 border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-blue-900/10 hover:-translate-y-2 transition-all duration-300 group overflow-hidden">
          
          {/* 巨大的数字水印 (01, 02...) */}
          <div class="absolute -right-4 -top-8 text-9xl font-black text-slate-200/50 group-hover:text-blue-50 transition-colors select-none">
            {String(index + 1).padStart(2, '0')}
          </div>
          
          <div class="relative z-10">
            <h3 class="text-xl font-extrabold text-slate-900 mb-4 tracking-tight group-hover:text-blue-700 transition-colors">
              {item.title}
            </h3>
            <p class="text-slate-500 leading-relaxed font-medium">
              {item.description}
            </p>
          </div>
          
        </div>
      ))}
    </div>
    
  </div>
</section>