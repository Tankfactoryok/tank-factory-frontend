---
const { title, steps = [] } = Astro.props;
---
<section class="py-24 bg-white">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-zinc-900 mb-16">{title}</h2>
    
    <div class="space-y-12 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-zinc-300 before:to-transparent">
      {steps.map((step: any, index: number) => (
        <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group">
          <div class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-white bg-blue-600 text-white shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 font-bold z-10">
            {step.step_number || index + 1}
          </div>
          <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] bg-zinc-50 p-6 md:p-8 rounded-2xl border border-zinc-100 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="font-bold text-zinc-900 text-xl mb-3">{step.title}</h3>
            <p class="text-zinc-600 leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>