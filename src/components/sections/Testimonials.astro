---
const { title, cards = [] } = Astro.props;
---
<section class="py-20 bg-white border-b border-zinc-100">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-center text-zinc-900 mb-16">{title}</h2>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {cards.map((card: any) => (
        <div class="bg-zinc-50 p-8 rounded-2xl border border-zinc-100 relative overflow-hidden hover:border-blue-200 transition-colors">
          <svg class="absolute top-6 left-6 w-12 h-12 text-zinc-200 -z-0" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" /></svg>
          
          <p class="text-zinc-700 leading-relaxed mb-8 relative z-10 italic">"{card.content}"</p>
          
          <div class="flex items-center gap-4 relative z-10 mt-auto">
            <div class="w-12 h-12 bg-zinc-800 rounded-full overflow-hidden flex-shrink-0 flex items-center justify-center font-bold text-white text-lg">
              {card.avatar_url ? (
                <img src={card.avatar_url} alt={card.author} class="object-cover w-full h-full" />
              ) : (
                card.author.charAt(0)
              )}
            </div>
            <div>
              <h4 class="font-bold text-zinc-900">{card.author}</h4>
              <p class="text-sm text-zinc-500">{card.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>