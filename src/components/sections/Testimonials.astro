---
const { title, cards } = Astro.props;
---
<section class="py-32 bg-slate-950 text-white overflow-hidden relative">
  <div class="absolute inset-0 z-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-slate-800/50 via-slate-950 to-slate-950"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <span class="text-blue-500 font-bold tracking-widest text-sm uppercase">Client Endorsements</span>
      <h2 class="text-4xl md:text-5xl font-black tracking-tighter mt-4 text-white">{title}</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {cards && cards.map((card: any) => (
        <div class="bg-slate-900 p-8 rounded-3xl border border-slate-800 hover:border-slate-700 transition-colors">
          <div class="mb-6 text-blue-500 opacity-50">
            <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" /></svg>
          </div>
          <p class="text-slate-300 text-lg leading-relaxed mb-8 italic">"{card.content}"</p>
          <div class="flex items-center gap-4">
            {card.avatar_url ? (
              <img src={card.avatar_url} alt={card.author} class="w-12 h-12 rounded-full object-cover border border-slate-700" />
            ) : (
              <div class="w-12 h-12 bg-slate-800 rounded-full flex items-center justify-center font-bold text-blue-400 border border-slate-700">{card.author ? card.author.charAt(0) : "U"}</div>
            )}
            <div>
              <div class="font-bold text-white tracking-tight">{card.author}</div>
              <div class="text-slate-500 text-sm font-medium">{card.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>