---
// 🚨 核心修复：把 items 改成 questions，匹配 Strapi 的字段名
const { title, subtitle, questions } = Astro.props;
---
<section class="py-24 bg-slate-50">
  <div class="max-w-4xl mx-auto px-6">
    
    {/* 标题区 */}
    <div class="text-center mb-16">
      <span class="text-blue-600 font-bold tracking-widest text-sm uppercase">Technical Support</span>
      <h2 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tighter mt-4">
        {title || "Common Inquiries"}
      </h2>
      {subtitle && <p class="text-slate-500 mt-6 text-lg">{subtitle}</p>}
    </div>

    {/* 手风琴列表 */}
    <div class="space-y-4">
      {/* 🚨 这里也要跟着改成 questions.map */}
      {questions && questions.map((item: any) => (
        <details class="group bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden [&_summary::-webkit-details-marker]:hidden">
          
          <summary class="flex items-center justify-between cursor-pointer p-6 md:px-8 font-bold text-lg text-slate-900 hover:text-blue-700 hover:bg-slate-50/50 transition-colors">
            {/* 匹配 Strapi 里的 question 字段 */}
            <span class="pr-6">{item.question}</span>
            <span class="transition duration-300 group-open:-rotate-180 flex-shrink-0 bg-blue-50 text-blue-600 rounded-full p-2">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          
          {/* 展开的答案区：匹配 Strapi 里的 answer 字段 */}
          <div class="px-6 md:px-8 pb-8 text-slate-600 leading-relaxed font-medium">
            <div class="border-t border-slate-100 pt-6 mt-2">
              {item.answer}
            </div>
          </div>
          
        </details>
      ))}
    </div>
    
  </div>
</section>