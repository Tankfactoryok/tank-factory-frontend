---
const { title, questions = [] } = Astro.props;
---
<section class="py-20 bg-white">
  <div class="max-w-3xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-center text-zinc-900 mb-12">{title}</h2>
    <div class="space-y-4">
      {questions.map((q: any) => (
        <details class="group border border-zinc-200 rounded-lg bg-zinc-50 [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex cursor-pointer items-center justify-between gap-1.5 p-6 text-zinc-900 font-bold">
            <h3 class="text-lg pr-4">{q.question}</h3>
            <span class="shrink-0 rounded-full bg-white p-2 text-zinc-900 shadow-sm border border-zinc-200 group-open:-rotate-180 transition-transform duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </span>
          </summary>
          <div class="px-6 pb-6 text-zinc-600 leading-relaxed border-t border-zinc-200 pt-4">
            <p>{q.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>