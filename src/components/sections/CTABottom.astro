---
const { title, subtitle, button_text, bg_color } = Astro.props;
---
<section class="relative py-32 bg-slate-950 overflow-hidden" style={bg_color ? `background-color: ${bg_color};` : ''}>
  <div class="absolute inset-0 z-0 flex items-center justify-center">
    <div class="w-[800px] h-[300px] bg-blue-600/20 blur-[120px] rounded-full"></div>
  </div>
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <h2 class="text-5xl md:text-6xl font-black text-white tracking-tighter mb-8 leading-tight">
      {title || "Ready to Upgrade Your Systems?"}
    </h2>
    <p class="text-xl text-blue-100/70 max-w-2xl mx-auto mb-12 font-medium">
      {subtitle || "Connect with our engineering team today."}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
      <a href="#contact" class="px-10 py-5 bg-blue-600 hover:bg-blue-500 text-white text-lg font-black rounded-2xl transition-all shadow-[0_0_40px_-10px_rgba(37,99,235,0.5)] hover:-translate-y-1">
        {button_text || "Request a Quote Now"}
      </a>
    </div>
  </div>
</section>