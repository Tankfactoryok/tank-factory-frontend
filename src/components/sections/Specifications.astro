---
const { title, items } = Astro.props;
---
<section class="max-w-5xl mx-auto px-6 py-24 mb-20 bg-white">
  <div class="flex items-end justify-between mb-16 border-b border-slate-100 pb-8">
    <h2 class="text-4xl font-black text-slate-900 tracking-tighter mb-0">{title}</h2>
    <span class="text-sm font-mono text-slate-400">SERIES-700 / 2026 EDITION</span>
  </div>

  {/* 💡 紧致的双列布局 */}
  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-20 gap-y-2">
    {items && items.map((item: any) => (
      <div class="flex items-center justify-between py-6 border-b border-slate-50 group hover:bg-slate-50 transition-colors px-4 rounded-xl">
        <span class="text-slate-500 font-medium group-hover:text-slate-900 transition-colors">{item.label}</span>
        <span class="text-blue-600 font-extrabold bg-blue-50/50 px-4 py-1.5 rounded-lg border border-blue-100/50">
          {item.value}
        </span>
      </div>
    ))}
  </div>
</section>