---
const { title, items } = Astro.props;
---
<section class="max-w-7xl mx-auto px-6 py-16 mb-16">
  
  <div class="text-center mb-16">
    <span class="inline-block bg-blue-100 text-blue-700 text-sm font-bold px-4 py-1.5 rounded-full uppercase tracking-wider mb-4">Field-Proven</span>
    <h2 class="text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight">{title}</h2>
  </div>

  {/* 💡 Tailwind Grid 魔法：一行三列，自动适应 */}
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
    {items && items.map((item: any) => (
      <div class="group bg-white rounded-3xl overflow-hidden border border-slate-200 shadow-sm hover:shadow-2xl hover:border-blue-200 hover:-translate-y-2 transition-all duration-300 flex flex-col">
        
        {/* 图片等高裁切与悬停放大 */}
        {item.image_url && (
          <div class="h-64 overflow-hidden bg-slate-100 relative">
            <img src={item.image_url} alt={item.industry} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
          </div>
        )}
        
        {/* 卡片内容区 */}
        <div class="p-8 flex flex-col flex-grow">
          {item.industry && (
            <span class="text-blue-600 font-bold text-sm uppercase tracking-wide mb-3">{item.industry}</span>
          )}
          
          <h3 class="text-2xl font-bold text-slate-900 mb-4 leading-snug">{item.result}</h3>
          <p class="text-slate-600 leading-relaxed">{item.description}</p>
        </div>
        
      </div>
    ))}
  </div>
</section>