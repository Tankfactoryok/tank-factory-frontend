---
const { title, items } = Astro.props;
---
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
      <div class="space-y-4 max-w-2xl">
        <span class="text-blue-600 font-bold tracking-widest text-sm uppercase">Global Applications</span>
        <h2 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tighter leading-none">
          {title || "Proven in the Field"}
        </h2>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {items && items.map((item: any) => (
        <div class="group rounded-3xl overflow-hidden cursor-pointer shadow-sm hover:shadow-2xl transition-all">
          <div class="relative h-64 overflow-hidden">
            {item.image_url ? (
               <img src={item.image_url} alt={item.industry} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            ) : (
               <div class="w-full h-full bg-slate-800 flex items-center justify-center text-slate-500 font-mono">Image PlaceHolder</div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/40 to-transparent opacity-90 group-hover:opacity-70 transition-opacity"></div>
            <div class="absolute bottom-0 left-0 p-8 w-full translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
              <span class="text-blue-400 font-bold text-sm tracking-wider uppercase mb-2 block">{item.result}</span>
              <h3 class="text-2xl font-black text-white tracking-tight mb-2">{item.industry}</h3>
              <p class="text-slate-300 font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-500 line-clamp-2">{item.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>