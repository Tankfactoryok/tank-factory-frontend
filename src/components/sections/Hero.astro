---
const { title, subtitle, cta_text, image_url } = Astro.props;
---
<section class="relative flex flex-col items-center justify-center min-h-[85vh] text-center px-6 overflow-hidden rounded-b-[4rem] mb-24 bg-slate-900 shadow-2xl">
  
  {/* 💡 物理背景：全屏图片 + 叠加遮罩 */}
  {image_url && (
    <div class="absolute inset-0 z-0">
      <img src={image_url} alt={title} class="w-full h-full object-cover opacity-60 scale-105" />
      <div class="absolute inset-0 bg-gradient-to-b from-slate-900/40 via-slate-900/80 to-slate-900/95"></div>
    </div>
  )}

  {/* 💡 悬浮文本层 */}
  <div class="relative z-10 max-w-6xl mx-auto flex flex-col items-center">
    <h1 class="text-5xl md:text-7xl lg:text-8xl font-black text-white tracking-tighter leading-[1.1] mb-8 drop-shadow-2xl">
      {title}
    </h1>
    
    {subtitle && (
      <p class="text-xl md:text-2xl text-slate-300 mb-12 max-w-3xl leading-relaxed font-light">
        {subtitle}
      </p>
    )}
    
    {cta_text && (
      <div class="flex flex-wrap gap-6 justify-center">
        <a href="/contact" class="bg-blue-600 hover:bg-blue-500 text-white font-black text-xl py-5 px-12 rounded-2xl shadow-[0_20px_40px_-10px_rgba(37,99,235,0.6)] transition-all transform hover:-translate-y-2 active:scale-95">
          {cta_text}
        </a>
      </div>
    )}
  </div>
</section>