---
const { title, items = [] } = Astro.props;
---
<section class="py-20 bg-zinc-50">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-center text-zinc-900 mb-12">{title}</h2>
    <div class="overflow-x-auto bg-white rounded-xl shadow-sm border border-zinc-200">
      <table class="w-full text-left border-collapse min-w-[600px]">
        <thead>
          <tr class="bg-zinc-100 border-b border-zinc-200">
            <th class="py-5 px-6 font-semibold text-zinc-700 w-1/3">Performance Metrics</th>
            <th class="py-5 px-6 font-bold text-blue-700 w-1/3 bg-blue-50 border-x border-blue-100">Fortis Systems Group</th>
            <th class="py-5 px-6 font-semibold text-zinc-500 w-1/3">Industry Standard</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-200">
          {items.map((item: any) => (
            <tr class="hover:bg-zinc-50 transition-colors">
              <td class="py-4 px-6 font-medium text-zinc-800">{item.label}</td>
              <td class="py-4 px-6 text-blue-800 font-bold bg-blue-50/30 border-x border-blue-100 flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                {item.our_product}
              </td>
              <td class="py-4 px-6 text-zinc-500">{item.competitor}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>