---
// 接收从 Strapi 传过来的零件
const { title, subtitle, cta_text } = Astro.props;
---

<section class="bg-gray-900 text-white py-20 px-8">
  <div class="max-w-4xl mx-auto text-center">
    <h1 class="text-5xl font-bold mb-6">{title}</h1>
    <p class="text-xl text-gray-300 mb-10">{subtitle}</p>
    <button class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg transition">
      {cta_text}
    </button>
  </div>
</section>
